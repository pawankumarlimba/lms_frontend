# ---------------------------------------------------------------------------
# LMS Frontend - Environment Variables
# Copy to .env.local and adjust for your environment.
# ---------------------------------------------------------------------------

# Base URL of the backend API (must include /api)
NEXT_PUBLIC_API_BASE_URL=https://lms-backend-nine-azure.vercel.app/api

# Must match JWT_COOKIE_NAME in the backend .env (used only to check
# cookie *presence* in middleware - the token itself is httpOnly and
# verified solely by the backend)
NEXT_PUBLIC_JWT_COOKIE_NAME=lms_token
